{
  "name": "okf",
  "version": "0.0.3",
  "description": "Generate and validate Open Knowledge Format bundles with LangChain and your preferred model provider.",
  "author": {
    "name": "Ovi Shekh",
    "url": "https://github.com/ovishkh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ovishkh/okf.git"
  },
  "homepage": "https://github.com/ovishkh/okf#readme",
  "bugs": {
    "url": "https://github.com/ovishkh/okf/issues"
  },
  "type": "module",
  "bin": {
    "okf": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    ".agents",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "okf",
    "open-knowledge-format",
    "knowledge-graph",
    "knowledge-base",
    "documentation-generator",
    "langchain",
    "nebius",
    "openrouter",
    "ollama",
    "llm",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.2",
    "@langchain/ollama": "^1.3.0",
    "@langchain/openai": "^1.5.5",
    "@langchain/openrouter": "^0.4.5",
    "boxen": "^8.0.1",
    "commander": "^15.0.0",
    "cytoscape": "^3.34.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.6",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "sanitize-html": "^2.17.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^26.1.1",
    "@types/sanitize-html": "^2.16.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
